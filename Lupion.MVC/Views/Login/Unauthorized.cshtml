@{
    ViewBag.Title = "Yetkisiz Erişim";
    Layout = null;
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="~/assets/images/favicon-32x32.png" type="image/png" />
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/assets/css/bootstrap-extended.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="~/assets/css/app.css" rel="stylesheet">
    <link href="~/assets/css/icons.css" rel="stylesheet">
    <link href="~/css/login.css" rel="stylesheet">
    <title>401 - Yetkisiz Erişim | Empty_ERP_Template ERP</title>
    <style>
        .unauthorized-card {
            background-color: #fff;
            padding: 2.5rem;
            border-radius: 1rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
            width: 100%;
            max-width: 420px;
            text-align: center;
        }
        .unauthorized-icon {
            width: 100px;
            height: 100px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, #ff7f00 0%, #ffaa00 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: #fff;
        }
        .unauthorized-code {
            font-size: 4rem;
            font-weight: 700;
            color: #ff7f00;
            line-height: 1;
            margin-bottom: 0.25rem;
        }
        .unauthorized-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 0.75rem;
        }
        .unauthorized-text {
            color: #6c757d;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }
    </style>
</head>
<body class="login-body">
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="unauthorized-card">
            <div class="unauthorized-icon">
                <i class="bx bx-lock-alt"></i>
            </div>
            <div class="unauthorized-code">@(ViewBag.StatusCode ?? 401)</div>
            <h1 class="unauthorized-title">Yetkisiz Erişim</h1>
            <p class="unauthorized-text">
                Bu sayfaya izniniz yok. Lütfen yöneticinizden izin isteyin.
            </p>
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-cheetah btn-lg">
                <i class="bx bx-home-circle"></i> Ana Sayfaya Dön
            </a>
            <a href="@Url.Action("Index", "Login")" class="btn btn-outline-secondary btn-lg mt-2">
                <i class="bx bx-log-in-circle"></i> Giriş Sayfası
            </a>
        </div>
    </div>
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
</body>
</html>
