@using Empty_ERP_Template.Business.DTOs.Shared
@using Empty_ERP_Template.Data.Entities.SharedEntities
@model (IEnumerable<Currency> Currencies, IEnumerable<GeneralTypeDTO> PaymentTypes)

@{
    Layout = null;
    var currencies = Model.Item1;
    var paymentTypes = Model.Item2;
}

<form id="personnelSalaryForm">
    <input type="hidden" id="Id" name="Id" />
    <input type="hidden" id="PersonnelId" name="PersonnelId" />

    <div class="row mb-3">
        <div class="col-md-2">
            <label for="EffectiveDate" class="form-label fw-bold">Başlangıç Tarihi</label>
            <input type="date" class="form-control" id="EffectiveDate" name="EffectiveDate" />
        </div>
        <div class="col-md-2">
            <label for="CurrencyCode" class="form-label fw-bold">Para Birimi</label>
            <select class="form-select" id="CurrencyCode" name="CurrencyCode">
                <option value="">Seçiniz</option>
                @foreach (var item in currencies)
                {
                    <option value="@item.Code">@item.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label for="NetSalary" class="form-label fw-bold">Net Maaş</label>
            <input type="number" step="0.01" class="form-control" id="NetSalary" name="NetSalary" />
        </div>
        <div class="col-md-2">
            <label for="MealCardFee" class="form-label fw-bold">Yemek Kartı Ücreti</label>
            <input type="number" step="0.01" class="form-control" id="MealCardFee" name="MealCardFee" />
        </div>
        <div class="col-md-2">
            <label for="PaymentMethod" class="form-label fw-bold">Ödeme Yöntemi</label>
            <select class="form-select" id="PaymentTypeId" name="PaymentTypeId">
                <option value="">Seçiniz</option>
                @foreach (var pt in paymentTypes)
                {
                    <option value="@pt.Id">@pt.Name</option>
                }
            </select>
        </div>

    </div>

    <div class="row mb-3">
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label for="BankName" class="form-label fw-bold">Banka</label>
            <input type="text" class="form-control" id="BankName" name="BankName" maxlength="50" />
        </div>
        <div class="col-md-6">
            <label for="BankAccount" class="form-label fw-bold">Banka Hesabı</label>
            <input type="text" class="form-control" id="BankAccount" name="BankAccount" maxlength="100" />
        </div>

    </div>
    <div class="row mb-3">
        <div class="col-md-12">
            <label for="Notes" class="form-label fw-bold">Notlar</label>
            <textarea class="form-control" id="Notes" name="Notes" rows="2" maxlength="1000"></textarea>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-primary footer_btn" onclick="upsertPersonnelSalary()">Kaydet</button>
    </div>
</form>
