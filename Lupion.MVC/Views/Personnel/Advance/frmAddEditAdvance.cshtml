@using Lupion.Data.Entities.SharedEntities
@model IEnumerable<Currency>

@{
    Layout = null;
    var currencies = Model;
}

<form id="personnelAdvanceForm">
    <input type="hidden" id="Id" name="Id" />
    <input type="hidden" id="PersonnelId" name="PersonnelId" />

    <div class="row mb-3">
        <div class="col-md-6">
            <label for="AdvanceDate" class="form-label fw-bold">Avans Tarihi</label>
            <input type="date" class="form-control" id="AdvanceDate" name="AdvanceDate" required />
        </div>
        <div class="col-md-6">
            <label for="StartDeductionDate" class="form-label fw-bold">Kesinti Başlangıç Tarihi</label>
            <input type="date" class="form-control" id="StartDeductionDate" name="StartDeductionDate" required />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6">
            <label for="CurrencyCode" class="form-label fw-bold">Kur / Para Birimi</label>
            <select class="form-select" id="CurrencyCode" name="CurrencyCode">
                <option value="">Seçiniz</option>
                @foreach (var item in currencies)
                {
                    <option value="@item.Code">@item.Name</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label for="GivenAmount" class="form-label fw-bold">Verilen Tutar</label>
            <input type="number" step="0.01" class="form-control" id="GivenAmount" name="GivenAmount" required />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label for="DeductionMonths" class="form-label fw-bold">Kaç Ay Kesinti Yapılacağı</label>
            <input type="number" class="form-control" id="DeductionMonths" name="DeductionMonths" min="1" required />
        </div>
        <div class="col-md-6">
            <label for="DeductionAmountPerMonth" class="form-label fw-bold">Aylık Kesinti Tutarı</label>
            <input type="number" step="0.01" class="form-control" id="DeductionAmountPerMonth" name="DeductionAmountPerMonth" required />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <label for="Notes" class="form-label fw-bold">Not</label>
            <textarea class="form-control" id="Notes" name="Notes" rows="2" maxlength="1000"></textarea>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-primary footer_btn" onclick="upsertPersonnelAdvance()">Kaydet</button>
    </div>
</form>
