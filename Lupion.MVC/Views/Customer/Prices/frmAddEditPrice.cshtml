@{
    Layout = null;
}
<form id="customerPriceForm">
    <input type="hidden" name="Id" id="Id" />
    <input type="hidden" name="CustomerId" id="CustomerId" />
    <div class="row">
        <div class="col-md-6">
            <label class="form-label fw-bold">Fiyat Sözleşmesi Adı</label>
            <input type="text" name="Name" id="Name" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label fw-bold">Fiyat</label>
            <input type="number" name="Price" id="Price" class="form-control" step="0.01" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            <label class="form-label fw-bold">Çıkış Adresi</label>
            <input type="text" name="DepartureRegion" id="DepartureRegion" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label fw-bold">Varış Adresi</label>
            <input type="text" name="ArrivalRegion" id="ArrivalRegion" class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            <label class="form-label fw-bold">Yükleme Firması</label>
            <input type="text" name="DepartureCompany" id="DepartureCompany" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label fw-bold">Teslimat Firması</label>
            <input type="text" name="ArrivalCompany" id="ArrivalCompany" class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            @await Component.InvokeAsync("LocationSelector", new { prefix = "Departure", cityLabel = "Çıkış İl", townLabel = "Çıkış İlçe" })
        </div>
        <div class="col-md-6">
            @await Component.InvokeAsync("LocationSelector", new { prefix = "Arrival", cityLabel = "Varış İl", townLabel = "Varış İlçe" })
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-12">
            <label class="form-label fw-bold">Not</label>
            <textarea name="Note" id="Note" class="form-control"></textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="button" class="btn btn-primary footer_btn" onclick="upsertCustomerPrice()">Kaydet</button>
    </div>
</form>
