@using Lupion.MVC.Models
@model TripleCardLayout

<div id="tripleCardSplitter" class="row h-100" style="height: 100%;">
    <!-- Sol taraf -->
    <div class="col-12 col-lg-9 d-flex flex-column">
        <div class="card radius-5 w-100 flex-grow-1 d-flex flex-column">
            <div class="card-header">
                <div class="d-flex align-items-center">
                    <h6 class="mb-0">@Model.LeftTitle</h6>
                </div>
            </div>
            <div class="card-body d-flex flex-column flex-grow-1">
                <div class="grid_container flex-grow-1">
                    @Model.LeftContent
                </div>
            </div>
        </div>
    </div>

    <!-- SaÄŸ taraf -->
    <div class="col-12 col-lg-3 d-flex flex-column">
        <div id="tripleRightSplitter" class="d-flex flex-column flex-grow-1">
            <div class="card radius-5 w-100 mb-3 d-flex flex-column" style="flex: 1;">
                <div class="card-header">
                    <div class="d-flex align-items-center">
                        <h6 class="mb-0">@Model.RightTopTitle</h6>
                    </div>
                </div>
                <div class="card-body flex-grow-1 d-flex flex-column">
                    @Model.RightTopContent
                </div>
            </div>

            <div class="card radius-5 w-100 d-flex flex-column" style="flex: 1;">
                <div class="card-header">
                    <div class="d-flex align-items-center">
                        <h6 class="mb-0">@Model.RightBottomTitle</h6>
                    </div>
                </div>
                <div class="card-body flex-grow-1 d-flex flex-column">
                    @Model.RightBottomContent
                </div>
            </div>
        </div>
    </div>
</div>
