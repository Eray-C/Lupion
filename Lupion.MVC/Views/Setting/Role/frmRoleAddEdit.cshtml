@{
    Layout = null;
}
<form id="roleAddEditForm">
    <input type="hidden" id="Id" name="Id">
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label for="Name" class="form-label fw-bold">Rol Adı</label>
                <input type="text" class="form-control" id="Name" name="Name" required>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label for="Description" class="form-label fw-bold">Açıklama</label>
                <input type="text" class="form-control" id="Description" name="Description">
            </div>
        </div>
    </div>
    <div class="d-flex align-items-end">
        <button type="button" class="btn btn-primary footer_btn" onclick="upsertRole()">Kaydet</button>
    </div>
</form>
