@{
    ViewBag.Title = "Anasayfa";
}
<div class="dashboard-page">
<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3">
    <div class="col">
        <div class="card radius-5 border-start border-0 border-4 border-info">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Toplam Sevkiyat</p>
                        <h4 class="my-1 text-info" id="totalShipmentsValue">0</h4>
                        <p class="mb-0 font-13 text-muted" id="totalShipmentsChange">Geçen haftaya göre değişim yok</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-gradient-blues text-white ms-auto">
                        <i class="bx bxs-truck"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card radius-5 border-start border-0 border-4 border-danger">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Sevkiyat Geliri</p>
                        <h4 class="my-1 text-danger" id="totalRevenueValue">₺0</h4>
                        <p class="mb-0 font-13 text-muted" id="totalRevenueChange">Geçen haftaya göre değişim yok</p>
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-gradient-burning text-white ms-auto">
                        <i class="bx bxs-wallet"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card radius-5 border-start border-0 border-4 border-success">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Toplam Personel</p>
                        <h4 class="my-1 text-primary" id="totalPersonnelsValue">0</h4>
                        <p class="mb-0 font-13 text-muted" id="totalPersonnelChange">Geçen haftaya göre değişim yok</p>

                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-gradient-ohhappiness text-white ms-auto">
                        <i class="bx bxs-group"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card radius-5 border-start border-0 border-4 border-warning">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div>
                        <p class="mb-0 text-secondary">Toplam Müşteri</p>
                        <h4 class="my-1 text-warning" id="totalCustomersValue">0</h4>
                       <p class="mb-0 font-13 text-muted" id="totalCustomersChange">Geçen haftaya göre değişim yok</p> 
                    </div>
                    <div class="widgets-icons-2 rounded-circle bg-gradient-orange text-white ms-auto">
                        <i class="bx bxs-group"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 d-flex">
        <div class="card radius-5 flex-grow-1">
            <div class="card-header card-header-with-btn">
                <div class="d-flex align-items-center flex-wrap gap-2">
                    <div class="flex-grow-1 min-w-0">
                        <h6 class="mb-0">Bugünkü planlı sevkiyatlar</h6>
                        <small class="text-secondary" id="todaysPlannedSubtitle"></small>
                    </div>
                    <a href="/shipments" target="_blank" class="btn btn-sm btn-outline-primary btn-responsive flex-shrink-0">Sevkiyatlar</a>
                </div>
            </div>
            <div class="card-body">
                <div id="todaysPlannedEmpty" class="text-center text-muted py-4 d-none">Bugün için planlı sevkiyat yok.</div>
                <div id="todaysPlannedGridWrap" class="d-none dashboard-table-scroll">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Plan adı</th>
                                    <th>Müşteri</th>
                                    <th>Son gerçekleşme</th>
                                    <th>Yük tipi</th>
                                    <th class="text-end" style="width:130px;">İşlem</th>
                                </tr>
                            </thead>
                            <tbody id="todaysPlannedBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 d-flex">
        <div class="card radius-10 flex-grow-1">
            <div class="card-header">
                <div class="d-flex align-items-center">
                    <div>
                        <h6 class="mb-0">Son Sevkiyatlar</h6>
                    </div>
                </div>
            </div>
            <div class="card-body dashboard-table-scroll">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sevkiyat No</th>
                                <th>Müşteri</th>
                                <th>Durum</th>
                                <th>Tarih</th>
                                <th>Araç</th>
                                <th class="text-end" style="width:130px;">İşlem</th>
                            </tr>
                        </thead>
                        <tbody id="recentShipmentsBody">
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Veriler yükleniyor...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 d-flex">
        <div class="card radius-5 flex-grow-1">
            <div class="card-header card-header-with-btn">
                <div class="d-flex align-items-center flex-wrap gap-2">
                    <div class="flex-grow-1 min-w-0">
                        <h6 class="mb-0">Süresi geçmiş araç belgeleri</h6>
                        <small class="text-secondary" id="expiredVehicleDocsSubtitle"></small>
                    </div>
                    <a href="/vehicles" target="_blank" class="btn btn-sm btn-outline-primary btn-responsive flex-shrink-0">Araçlar</a>
                </div>
            </div>
            <div class="card-body">
                <div id="expiredVehicleDocsEmpty" class="text-center text-muted py-4 d-none">Süresi geçmiş veya yaklaşan araç belgesi yok.</div>
                <div id="expiredVehicleDocsGridWrap" class="d-none dashboard-table-scroll">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Araç</th>
                                    <th>Belge Tipi</th>
                                    <th>Belge No</th>
                                    <th>Bitiş Tarihi</th>
                                    <th>Kalan Gün</th>
                                </tr>
                            </thead>
                            <tbody id="expiredVehicleDocsBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 d-flex">
        <div class="card radius-5 flex-grow-1">
            <div class="card-header card-header-with-btn">
                <div class="d-flex align-items-center flex-wrap gap-2">
                    <div class="flex-grow-1 min-w-0">
                        <h6 class="mb-0">Süresi geçmiş dorse belgeleri</h6>
                        <small class="text-secondary" id="expiredTrailerDocsSubtitle"></small>
                    </div>
                    <a href="/trailers" target="_blank" class="btn btn-sm btn-outline-primary btn-responsive flex-shrink-0">Dorseler</a>
                </div>
            </div>
            <div class="card-body">
                <div id="expiredTrailerDocsEmpty" class="text-center text-muted py-4 d-none">Süresi geçmiş veya yaklaşan dorse belgesi yok.</div>
                <div id="expiredTrailerDocsGridWrap" class="d-none dashboard-table-scroll">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Dorse</th>
                                    <th>Belge Tipi</th>
                                    <th>Belge No</th>
                                    <th>Bitiş Tarihi</th>
                                    <th>Kalan Gün</th>
                                </tr>
                            </thead>
                            <tbody id="expiredTrailerDocsBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card radius-5 w-100">
            <div class="card-header">
                <div class="d-flex align-items-center">
                    <div>
                        <h6 class="mb-0">Geçmiş Aylara Göre Sevkiyat Görünümü</h6>

                        <small class="text-secondary" id="materialChartSubtitle"></small>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div id="materialChartEmpty" class="text-center text-muted py-5 d-none">Seçilen dönemde sevkiyat kaydı bulunamadı.</div>

                <div class="chart-container-1" id="materialChartContainer">
                    <canvas id="materialTypeChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card radius-10">
            <div class="card-header">
                <div class="d-flex align-items-center">
                    <div>
                        <h6 class="mb-0">Şehirlere göre sevkiyatlar</h6>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div id="turkeyMap"></div>
                    </div>
                    <div class="col-md-4">
                        <h6 class="mb-3 fw-bold">Şehirler</h6>
                        <div id="cityProgressList"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
</div>

<script src="~/js/Dashboard/Dashboard.js"></script>
<style>
    .highcharts-credits { display: none; }
    .dashboard-table-scroll { max-height: 320px; overflow: auto; }
    .dashboard-table-scroll .table-responsive { overflow: visible; }
</style>